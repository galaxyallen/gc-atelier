# Database — Supabase Postgres connection string (Settings → Database → URI)
DATABASE_URL="postgresql://user:password@localhost:5432/gcatelier?schema=public"

NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# One-time production seed: POST /api/setup with header x-setup-secret (set on Vercel only)
# SETUP_SECRET="generate-a-random-secret"

# Public site URL (production: https://gccreativehk.com)
# NEXT_PUBLIC_SITE_URL="https://gccreativehk.com"
# NEXT_PUBLIC_SHOP_CURRENCY="USD"

# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."  # from Stripe webhook: /api/payments/webhook
# STRIPE_CURRENCY="usd"              # usd | hkd | cny

# Supabase Storage — required for uploads on Vercel (create public bucket "uploads")
# NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
# SUPABASE_SERVICE_KEY="eyJ..."  # service_role key (server only, never expose to client)

# Local dev: save uploads to public/uploads instead of Supabase
# USE_LOCAL_UPLOADS="true"
