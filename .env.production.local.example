# Copy to .env.production.local and fill in values (never commit .env.production.local)

# Vercel — https://vercel.com/account/settings/tokens
VERCEL_TOKEN=

# Supabase Postgres (Transaction pooler URI recommended for serverless)
DATABASE_URL=

NEXTAUTH_SECRET=
NEXTAUTH_URL=https://gccreativehk.com
NEXT_PUBLIC_SITE_URL=https://gccreativehk.com

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=

NEXT_PUBLIC_SHOP_CURRENCY=USD
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# One-time only — remove from Vercel after POST /api/setup succeeds
# SETUP_SECRET=
